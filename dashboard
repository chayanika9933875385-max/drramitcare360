<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Health Dashboard — DrRamitCare 360</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', Arial, sans-serif; background: #f0f4f8; min-height: 100vh; }

    header {
      background: #0b2540;
      padding: 14px 32px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .logo { font-size: 18px; font-weight: 800; color: #d4a24c; text-decoration: none; }
    .logo span { color: #aaa; font-size: 12px; font-weight: 400; display: block; }
    .header-right { display: flex; align-items: center; gap: 16px; }
    .health-id-badge {
      background: rgba(212,162,76,0.15);
      border: 1px solid #d4a24c;
      color: #d4a24c;
      padding: 6px 14px;
      border-radius: 50px;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 1px;
    }
    .logout-btn {
      color: #aaa;
      font-size: 13px;
      cursor: pointer;
      text-decoration: none;
    }

    /* LOADING */
    .loading {
      text-align: center;
      padding: 100px 20px;
    }
    .spinner {
      width: 48px; height: 48px;
      border: 4px solid #e0e0e0;
      border-top-color: #d4a24c;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 0 auto 20px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* MAIN LAYOUT */
    .dashboard {
      display: none;
      max-width: 1100px;
      margin: 0 auto;
      padding: 28px 20px 60px;
    }

    /* WELCOME BAR */
    .welcome-bar {
      background: linear-gradient(135deg, #0b2540, #1a3a5c);
      color: white;
      border-radius: 20px;
      padding: 28px 32px;
      margin-bottom: 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 16px;
    }
    .welcome-bar h2 { font-size: 22px; font-weight: 700; }
    .welcome-bar h2 span { color: #d4a24c; }
    .welcome-bar p { color: #aac; font-size: 14px; margin-top: 4px; }
    .passport-btn {
      background: #d4a24c;
      color: #0b2540;
      border: none;
      padding: 11px 24px;
      border-radius: 50px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      text-decoration: none;
    }

    /* SCORE CARDS */
    .scores-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 16px;
      margin-bottom: 24px;
    }
    .score-card {
      background: #fff;
      border-radius: 16px;
      padding: 24px 20px;
      text-align: center;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }
    .score-card .sc-icon { font-size: 32px; margin-bottom: 8px; }
    .score-card .sc-num { font-size: 38px; font-weight: 800; color: #0b2540; }
    .score-card .sc-label { font-size: 12px; color: #888; margin-top: 4px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
    .score-card .sc-bar { background: #f0f4f8; border-radius: 50px; height: 6px; margin-top: 12px; overflow: hidden; }
    .score-card .sc-fill { height: 100%; border-radius: 50px; background: #d4a24c; transition: width 1s ease; }
    .score-card.green .sc-num { color: #27ae60; }
    .score-card.green .sc-fill { background: #27ae60; }
    .score-card.blue .sc-num { color: #2980b9; }
    .score-card.blue .sc-fill { background: #2980b9; }

    /* INFO SECTION */
    .info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 24px;
    }
    .info-card {
      background: #fff;
      border-radius: 16px;
      padding: 24px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }
    .info-card h3 {
      font-size: 15px;
      font-weight: 700;
      color: #0b2540;
      margin-bottom: 16px;
      padding-bottom: 10px;
      border-bottom: 1px solid #f0f0f0;
    }
    .info-row {
      display: flex;
      justify-content: space-between;
      padding: 8px 0;
      font-size: 14px;
      border-bottom: 1px solid #f8f8f8;
    }
    .info-row:last-child { border-bottom: none; }
    .info-row .ilabel { color: #888; }
    .info-row .ivalue { color: #0b2540; font-weight: 600; }

    /* QUICK ACTIONS */
    .quick-actions {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 14px;
      margin-bottom: 24px;
    }
    .qa-btn {
      background: #fff;
      border: 1.5px solid #eee;
      border-radius: 14px;
      padding: 20px 16px;
      text-align: center;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.2s;
      display: block;
    }
    .qa-btn:hover { border-color: #d4a24c; transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,0.08); }
    .qa-btn .qa-icon { font-size: 28px; margin-bottom: 8px; }
    .qa-btn .qa-label { font-size: 13px; font-weight: 600; color: #0b2540; }

    /* PREVENTIVE RECS */
    .section-card {
      background: #fff;
      border-radius: 16px;
      padding: 24px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      margin-bottom: 20px;
    }
    .section-card h3 {
      font-size: 16px;
      font-weight: 700;
      color: #0b2540;
      margin-bottom: 16px;
    }
    .rec-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 12px 0;
      border-bottom: 1px solid #f5f5f5;
    }
    .rec-item:last-child { border-bottom: none; }
    .rec-icon { font-size: 24px; flex-shrink: 0; }
    .rec-text { flex: 1; }
    .rec-name { font-size: 14px; font-weight: 600; color: #0b2540; }
    .rec-freq { font-size: 12px; color: #888; margin-top: 2px; }
    .rec-badge {
      font-size: 11px;
      padding: 4px 10px;
      border-radius: 50px;
      font-weight: 600;
    }
    .badge-dental { background: #fff4e0; color: #d4a24c; }
    .badge-blood { background: #ffe0e0; color: #c0392b; }
    .badge-heart { background: #ffe0f0; color: #c0247e; }
    .badge-eye { background: #e0f0ff; color: #2980b9; }
    .badge-cancer { background: #f0e0ff; color: #8e44ad; }

    /* MEMBERSHIP */
    .membership-banner {
      background: linear-gradient(135deg, #d4a24c, #c49040);
      border-radius: 16px;
      padding: 24px;
      color: #0b2540;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 16px;
      margin-bottom: 20px;
    }
    .membership-banner.active {
      background: linear-gradient(135deg, #0b2540, #1a3a5c);
      color: white;
    }
    .membership-banner h3 { font-size: 18px; font-weight: 800; }
    .membership-banner p { font-size: 14px; opacity: 0.8; margin-top: 4px; }
    .mem-join-btn {
      background: #0b2540;
      color: #d4a24c;
      border: none;
      padding: 11px 24px;
      border-radius: 50px;
      font-weight: 700;
      font-size: 14px;
      cursor: pointer;
      text-decoration: none;
    }
    .membership-banner.active .mem-join-btn {
      background: #d4a24c;
      color: #0b2540;
    }

    @media(max-width:600px) {
      .info-grid { grid-template-columns: 1fr; }
      .welcome-bar { flex-direction: column; align-items: flex-start; }
      header { padding: 14px 16px; }
    }
  </style>
</head>
<body>

<header>
  <a href="index.html" class="logo">
    🩺 DrRamitCare 360
    <span>Your Personal Digital Health Office</span>
  </a>
  <div class="header-right">
    <span class="health-id-badge" id="headerHealthId">Loading...</span>
    <a href="register.html" class="logout-btn" onclick="sessionStorage.clear()">Logout</a>
  </div>
</header>

<!-- LOADING STATE -->
<div class="loading" id="loadingState">
  <div class="spinner"></div>
  <p style="color:#666">Loading your health dashboard...</p>
</div>

<!-- DASHBOARD -->
<div class="dashboard" id="dashboardContent">

  <!-- WELCOME -->
  <div class="welcome-bar">
    <div>
      <h2>Welcome, <span id="patientName">--</span> 👋</h2>
      <p id="patientSubtitle">Health ID: -- | Registered Member</p>
    </div>
    <a href="#" class="passport-btn" id="passportBtn" onclick="generatePassport(event)">
      📄 Download Health Passport
    </a>
  </div>

  <!-- SCORE CARDS -->
  <div class="scores-grid">
    <div class="score-card">
      <div class="sc-icon">⚕️</div>
      <div class="sc-num" id="sc_health">--</div>
      <div class="sc-label">Overall Health Score</div>
      <div class="sc-bar"><div class="sc-fill" id="bar_health" style="width:0%"></div></div>
    </div>
    <div class="score-card">
      <div class="sc-icon">🦷</div>
      <div class="sc-num" id="sc_dental">--</div>
      <div class="sc-label">Dental Score</div>
      <div class="sc-bar"><div class="sc-fill" id="bar_dental" style="width:0%"></div></div>
    </div>
    <div class="score-card green">
      <div class="sc-icon">🏃</div>
      <div class="sc-num" id="sc_lifestyle">--</div>
      <div class="sc-label">Lifestyle Score</div>
      <div class="sc-bar"><div class="sc-fill green" id="bar_lifestyle" style="width:0%"></div></div>
    </div>
    <div class="score-card blue">
      <div class="sc-icon">⚖️</div>
      <div class="sc-num" id="sc_bmi">--</div>
      <div class="sc-label">BMI</div>
      <div class="sc-bar"><div class="sc-fill blue" id="bar_bmi" style="width:0%"></div></div>
    </div>
  </div>

  <!-- QUICK ACTIONS -->
  <div class="quick-actions">
    <a href="#" class="qa-btn">
      <div class="qa-icon">📅</div>
      <div class="qa-label">Book Appointment</div>
    </a>
    <a href="#" class="qa-btn">
      <div class="qa-icon">📋</div>
      <div class="qa-label">Add Report</div>
    </a>
    <a href="#" class="qa-btn">
      <div class="qa-icon">👨‍👩‍👧</div>
      <div class="qa-label">Family Office</div>
    </a>
    <a href="#" class="qa-btn">
      <div class="qa-icon">🔔</div>
      <div class="qa-label">Set Reminder</div>
    </a>
    <a href="#" class="qa-btn">
      <div class="qa-icon">🧭</div>
      <div class="qa-label">Health Navigator</div>
    </a>
    <a href="#" class="qa-btn">
      <div class="qa-icon">📊</div>
      <div class="qa-label">Health Timeline</div>
    </a>
  </div>

  <!-- PERSONAL INFO + HEALTH INFO -->
  <div class="info-grid">
    <div class="info-card">
      <h3>👤 Personal Information</h3>
      <div class="info-row"><span class="ilabel">Full Name</span><span class="ivalue" id="info_name">--</span></div>
      <div class="info-row"><span class="ilabel">Age</span><span class="ivalue" id="info_age">--</span></div>
      <div class="info-row"><span class="ilabel">Gender</span><span class="ivalue" id="info_gender">--</span></div>
      <div class="info-row"><span class="ilabel">Blood Group</span><span class="ivalue" id="info_blood">--</span></div>
      <div class="info-row"><span class="ilabel">Phone</span><span class="ivalue" id="info_phone">--</span></div>
    </div>
    <div class="info-card">
      <h3>🏥 Medical Information</h3>
      <div class="info-row"><span class="ilabel">Height</span><span class="ivalue" id="info_height">--</span></div>
      <div class="info-row"><span class="ilabel">Weight</span><span class="ivalue" id="info_weight">--</span></div>
      <div class="info-row"><span class="ilabel">BMI</span><span class="ivalue" id="info_bmi">--</span></div>
      <div class="info-row"><span class="ilabel">Allergies</span><span class="ivalue" id="info_allergies">--</span></div>
      <div class="info-row"><span class="ilabel">Conditions</span><span class="ivalue" id="info_conditions">--</span></div>
    </div>
  </div>

  <!-- MEMBERSHIP BANNER -->
  <div class="membership-banner" id="membershipBanner">
    <div>
      <h3>🛡️ Join Preventive Membership</h3>
      <p>Monthly health reviews, personalized guidance & smart reminders — year-round care</p>
    </div>
    <a href="#" class="mem-join-btn">Join Now →</a>
  </div>

  <!-- PREVENTIVE RECOMMENDATIONS -->
  <div class="section-card">
    <h3>🔬 Your Preventive Care Checklist</h3>
    <div id="preventiveList">
      <p style="color:#888; font-size:14px">Loading recommendations...</p>
    </div>
  </div>

</div><!-- end dashboard -->

<script>
  const API_URL = 'https://script.google.com/macros/s/AKfycbz2oPhBt8r3afKCdFbZqyhmb-yaPkn5XywFtgkPyUyAuK-AYHniMhR_aDyHh8zC457U/exec';

  const typeIcons = { Dental:'🦷', Blood:'🩸', Heart:'❤️', Eye:'👁️', Cancer:'🎗️' };
  const typeBadge = { Dental:'badge-dental', Blood:'badge-blood', Heart:'badge-heart', Eye:'badge-eye', Cancer:'badge-cancer' };

  async function loadDashboard() {
    const params = new URLSearchParams(window.location.search);
    let healthId = params.get('id') || sessionStorage.getItem('healthId');

    if (!healthId) {
      window.location.href = 'register.html';
      return;
    }

    try {
      const url = new URL(API_URL);
      url.searchParams.append('action', 'getPatientDashboard');
      url.searchParams.append('healthId', healthId);
      const res = await fetch(url.toString());
      const data = await res.json();

      if (!data.success) {
        window.location.href = 'register.html';
        return;
      }

      // Fill header
      document.getElementById('headerHealthId').textContent = data.healthId;
      sessionStorage.setItem('healthId', data.healthId);

      // Fill welcome
      document.getElementById('patientName').textContent = data.name;
      document.getElementById('patientSubtitle').textContent = 'Health ID: ' + data.healthId + ' | ' + (data.gender || '') + ' | Registered Member';

      // Fill scores
      setScore('sc_health', 'bar_health', data.healthScore);
      setScore('sc_dental', 'bar_dental', data.dentalScore);
      setScore('sc_lifestyle', 'bar_lifestyle', data.lifestyleScore);

      const bmi = Number(data.bmi);
      document.getElementById('sc_bmi').textContent = bmi ? bmi.toFixed(1) : '--';
      const bmiPct = bmi ? Math.min(100, (bmi / 40) * 100) : 0;
      setTimeout(() => { document.getElementById('bar_bmi').style.width = bmiPct + '%'; }, 200);

      // Fill personal info
      document.getElementById('info_name').textContent = data.name || '--';
      document.getElementById('info_age').textContent = data.age ? data.age + ' years' : '--';
      document.getElementById('info_gender').textContent = data.gender || '--';
      document.getElementById('info_blood').textContent = data.bloodGroup || '--';
      document.getElementById('info_phone').textContent = data.phone || '--';
      document.getElementById('info_height').textContent = data.height ? data.height + ' cm' : '--';
      document.getElementById('info_weight').textContent = data.weight ? data.weight + ' kg' : '--';
      document.getElementById('info_bmi').textContent = bmi ? bmi.toFixed(1) + getBmiLabel(bmi) : '--';
      document.getElementById('info_allergies').textContent = data.allergies || 'None';
      document.getElementById('info_conditions').textContent = data.conditions || 'None';

      // Load preventive recs
      loadPreventiveRecs(data.age, data.gender);

      // Show dashboard
      document.getElementById('loadingState').style.display = 'none';
      document.getElementById('dashboardContent').style.display = 'block';

    } catch (e) {
      document.getElementById('loadingState').innerHTML = '<p style="color:#c0392b">❌ Dashboard load nahi ho saka. Internet check karein aur page refresh karein.</p>';
    }
  }

  function setScore(numId, barId, value) {
    const v = Number(value) || 0;
    document.getElementById(numId).textContent = v + '/100';
    setTimeout(() => { document.getElementById(barId).style.width = v + '%'; }, 200);
  }

  function getBmiLabel(bmi) {
    if (bmi < 18.5) return ' (Underweight)';
    if (bmi < 25) return ' (Normal ✅)';
    if (bmi < 30) return ' (Overweight)';
    return ' (Obese)';
  }

  async function loadPreventiveRecs(age, gender) {
    try {
      const url = new URL(API_URL);
      url.searchParams.append('action', 'getPreventiveRecommendations');
      url.searchParams.append('age', age || 30);
      url.searchParams.append('gender', gender || 'Male');
      const res = await fetch(url.toString());
      const data = await res.json();

      if (data.success && data.recommendations) {
        const container = document.getElementById('preventiveList');
        container.innerHTML = data.recommendations.map(r => `
          <div class="rec-item">
            <div class="rec-icon">${typeIcons[r.type] || '🔬'}</div>
            <div class="rec-text">
              <div class="rec-name">${r.item}</div>
              <div class="rec-freq">${r.frequency}</div>
            </div>
            <span class="rec-badge ${typeBadge[r.type] || 'badge-blood'}">${r.type}</span>
          </div>
        `).join('');
      }
    } catch(e) {}
  }

  async function generatePassport(e) {
    e.preventDefault();
    const healthId = sessionStorage.getItem('healthId');
    if (!healthId) return;
    const btn = document.getElementById('passportBtn');
    btn.textContent = '⏳ Generating...';
    try {
      const url = new URL(API_URL);
      url.searchParams.append('action', 'generateHealthPassportPdf');
      url.searchParams.append('healthId', healthId);
      const res = await fetch(url.toString());
      const data = await res.json();
      if (data.success && data.pdfUrl) {
        window.open(data.pdfUrl, '_blank');
        btn.textContent = '📄 Download Health Passport';
      } else {
        btn.textContent = '📄 Download Health Passport';
        alert('PDF generation mein problem aayi. Baad mein try karein.');
      }
    } catch(e) {
      btn.textContent = '📄 Download Health Passport';
    }
  }

  loadDashboard();
</script>

</body>
</html>
